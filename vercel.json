{
  "functions": {
    "src/app/api/cron/daily-summary/route.js": {
      "maxDuration": 60
    },
    "src/app/api/cron/breaking-news/route.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/cron/midnight-reset",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/daily-summary",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/push-notify",
      "schedule": "0 17 * * *"
    },
    {
      "path": "/api/cron/breaking-news",
      "schedule": "0 * * * *"
    }
  ]
}
